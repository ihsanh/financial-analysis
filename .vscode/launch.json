{
    "configurations": [
        {
            "type": "java",
            "name": "FinAnalysis (H2 - geliştirme)",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "com.finanalysis.FinancialAnalysisApplication",
            "projectName": "financial-analysis",
            "args": "--spring.profiles.active=h2",
            "vmArgs": "-Dfile.encoding=UTF-8"
        },
        {
            "type": "java",
            "name": "FinAnalysis (PostgreSQL - üretim)",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "com.finanalysis.FinancialAnalysisApplication",
            "projectName": "financial-analysis",
            "args": "--spring.profiles.active=postgres",
            "vmArgs": "-Dfile.encoding=UTF-8"
        }
    ]
}
